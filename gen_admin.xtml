<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>ASHMETAL666 - JSON Admin Generator</title>
    <style>
        body { background: #111; color: #fff; font-family: sans-serif; padding: 20px; }
        .form-group { margin-bottom: 12px; }
        label { display: block; margin-bottom: 5px; color: #c00000; font-weight: bold;}
        input[type="text"] { width: 100%; padding: 10px; background: #222; border: 1px solid #444; color: #fff; box-sizing: border-box;}
        button { background: #c00000; color: #fff; border: none; padding: 10px 15px; cursor: pointer; font-weight: bold; margin-right: 10px;}
        button.reset { background: #444; }
        textarea { width: 100%; height: 120px; background: #1a1a1a; color: #00ff00; font-family: monospace; padding: 10px; margin-top: 20px; box-sizing: border-box; border: 1px solid #333;}
    </style>
</head>
<body>

    <h2>ASHMETAL666 JSON ENTRY GENERATOR</h2>
    <hr border="1" color="#c00000">
    <br>

    <div class="form-group">
        <label>URL MP3 Dropbox</label>
        <input type="text" id="src" placeholder="https://dl.dropboxusercontent.com/...">
    </div>
    <div class="form-group">
        <label>Judul Lagu</label>
        <input type="text" id="title" placeholder="Misal: Bloody Prophecy">
    </div>
    <div class="form-group">
        <label>Nama Band</label>
        <input type="text" id="artist" placeholder="Misal: The Salvatory">
    </div>
    <div class="form-group">
        <label>URL Thumbnail</label>
        <input type="text" id="img" placeholder="http://...">
    </div>

    <button onclick="generateJSON()">Generate JSON</button>
    <button class="reset" onclick="resetForm()">Reset Form</button>

    <textarea id="output" readonly placeholder="Hasil format JSON akan muncul di sini..."></textarea>
    <br><br>
    <button onclick="copyJSON()" style="background:#0088cc;">Copy JSON</button>

    <script>
        function generateJSON() {
            const src = document.getElementById('src').value.trim();
            const title = document.getElementById('title').value.trim();
            const artist = document.getElementById('artist').value.trim();
            const img = document.getElementById('img').value.trim();

            if(!src || !title || !artist || !img) {
                alert('Semua bidang input wajib diisi!');
                return;
            }

            const jsonObj = { src, title, artist, img };
            // Hasil cetak mentah ditambahkan koma di ujung sesuai request untuk mempermudah append massal
            const resultString = JSON.stringify(jsonObj, null, 2) + ",";
            document.getElementById('output').value = resultString;
        }

        function resetForm() {
            document.getElementById('src').value = '';
            document.getElementById('title').value = '';
            document.getElementById('artist').value = '';
            document.getElementById('img').value = '';
            document.getElementById('output').value = '';
        }

        function copyJSON() {
            const output = document.getElementById('output');
            output.select();
            document.execCommand('copy');
            alert('Format teks JSON berhasil disalin!');
        }
    </script>
</body>
</html>
